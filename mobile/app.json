{
  "expo": {
    "name": "AI Caddie",
    "slug": "ai-caddie",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ai-caddie",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cAIddie.aicaddie",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D6A4F"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-iap"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "72e2815a-f546-4b3e-a788-1b8d316f8995"
      }
    }
  }
}
